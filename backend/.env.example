# ============================================================
#  UniFi Backend — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5050
APP_URL=http://localhost:5050
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Safety switch: never return OTP in API response unless explicitly true in development
EXPOSE_DEV_OTP=false
ALLOWED_UNIVERSITY_DOMAINS=lpu.in,rguktn.ac.in
# Backward-compatible key used by seed script (optional)
ALLOWED_UNIVERSITY_DOMAIN=lpu.in

# ── Database ─────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/unifi_db"
# On deploy, run seed after schema sync (Render-friendly when shell access is unavailable)
DB_SEED_ON_DEPLOY=true

# ── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="aa15b57de71ce582c6a44c680a313d9d196cdfbbae0648afc8984a2ef4934fa6c0238a43a508e705b883f35583d349bff6709d16a5d677c0c43e2f2994bb89ba"
JWT_REFRESH_SECRET="d7a2ac9a5b7b0a8ba6445ecc407e4b514ef7cd709a8d197fd90aa4cce5e7d2f22202ddee6e5b5581d0fc6bb880c9ea5526c8871e22a28c5b8f0c0901f0442a5d"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Encryption (AES-256 for UPI IDs) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="86aca9d4c8527f8b5151c78b6d5040c422a93cedd3db0608c2e57283469ddca0"

# ── Razorpay ─────────────────────────────────────────────────
# PAYMENT_PROVIDER=MOCK (local full-flow without gateway)
# PAYMENT_PROVIDER=RAZORPAY (real integration)
PAYMENT_PROVIDER=MOCK
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
RAZORPAY_WEBHOOK_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
# Extra signature + amount verification via Razorpay API on /payments/verify
RAZORPAY_VERIFY_API=true

# ── Email (Nodemailer) ────────────────────────────────────────
# For production, use your SMTP provider (Brevo/SendGrid/Mailgun/SES etc.)
# Typical values:
#   Port 587 => SMTP_SECURE=false
#   Port 465 => SMTP_SECURE=true
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_ALLOW_SELF_SIGNED=false
SMTP_STRICT=true
SMTP_VERIFY_ON_STARTUP=false
SMTP_CONNECTION_TIMEOUT_MS=12000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
SMTP_FROM_NAME="UniFi"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password_or_key"
SMTP_FROM="noreply@yourdomain.com"
SMTP_TEST_TO="you@yourdomain.com"

# ── SMS OTP Fallback ─────────────────────────────────────────
# SMS_PROVIDER=MOCK (logs OTP server-side), SMS_PROVIDER=TWILIO (real SMS)
SMS_PROVIDER=MOCK
SMS_STRICT=false
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""  # E.164 format, e.g. +14155552671

# ── File Storage (Cloudflare R2 — free 10GB) ─────────────────
# Or use AWS S3 — same API
R2_ACCESS_KEY_ID="XXXXXXXXXXXXXXXXXXXXXXXX"
R2_SECRET_ACCESS_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
R2_BUCKET_NAME="unifi-kyc-docs"
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://your-r2-domain.com"  # Only for non-sensitive assets

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000    # 1 minute
RATE_LIMIT_MAX_REQUESTS=100   # per IP per window
AUTH_RATE_LIMIT_MAX=10        # stricter for auth endpoints
OTP_RATE_LIMIT_MAX=3          # per IP per minute for resend/verify OTP

# ── Collections / Risk Controls ──────────────────────────────
DEFAULT_AFTER_DAYS=15         # Auto mark ACTIVE loan as DEFAULTED after due date + N days
LATE_FEE_PER_DAY_BPS=50       # 50 bps = 0.5% late fee per overdue day
MAX_LATE_FEE_PCT=20           # Cap late fee at 20% of principal

# ── Admin ─────────────────────────────────────────────────────
ADMIN_URL_PREFIX="/admin-x7k2"   # Obscure the admin URL
